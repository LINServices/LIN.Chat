@rendermode RenderMode.InteractiveWebAssembly

@inject IJSRuntime JSRuntime
@inject NavigationManager Navigation

@* Cabecera extraída como componente *@
<ChatHeader Iam="@_iam"
            OnBackPress="@OnBackPress"
            OnCall="Call"
            EmmaClick="@EmmaClick"
            OnMembers="OpenDrawer" />

@* Área de mensajes *@
<div id="CM-@(Iam?.Conversation?.Id ?? 0)"
     class="scroll-ui flex-1 overflow-auto bg-gray-50 dark:bg-zinc-950
            [&::-webkit-scrollbar]:w-1.5
            [&::-webkit-scrollbar-track]:bg-transparent
            [&::-webkit-scrollbar-thumb]:rounded-full
            [&::-webkit-scrollbar-thumb]:bg-gray-200
            dark:[&::-webkit-scrollbar-thumb]:bg-zinc-800">

    <div id="CM-@(Iam?.Conversation?.Id ?? 0)" class="px-4 py-4">

        @* Fecha de creación *@
        <div class="my-5 flex justify-center">
            <div class="rounded-full bg-current-100 px-4 py-1 dark:bg-current-500/20">
                <p class="text-xs text-current-700 dark:text-current-300">
                    @DateTime.Now.ToString("MMMM dd, yyyy")
                </p>
            </div>
        </div>

        @* Aviso de seguridad *@
        <div class="mb-6 flex justify-center">
            <div class="rounded-2xl bg-amber-50 px-5 py-1.5 dark:bg-amber-900/20">
                <p class="text-xs text-amber-700 dark:text-amber-400">
                    Tus mensajes están protegidos y cifrados
                </p>
            </div>
        </div>

        @* Renderizado de mensajes *@
        @foreach (var message in Iam?.Messages ?? [])
        {
            oldTime ??= message.Time;

            if (new DateTime(oldTime.Value.Year, oldTime.Value.Month, oldTime.Value.Day) < new DateTime(message.Time.Year, message.Time.Month, message.Time.Day))
            {
                var dateMess = new DateTime(message.Time.Year, message.Time.Month, message.Time.Day);
                var isToday = dateMess == Today;

                <div class="mb-3 mt-6 flex justify-center">
                    <div class="rounded-full bg-current-100 px-4 py-1 dark:bg-current-500/20">
                        <p class="text-xs text-current-700 dark:text-current-300">
                            @if (isToday)
                            {
                                @("Hoy")
                            }
                            else if (dateMess == Today.AddDays(-1))
                            {
                                @("Ayer")
                            }
                            else
                            {
                                @message.Time.ToString("MMMM dd, yyyy")
                            }
                        </p>
                    </div>
                </div>
                oldTime = message.Time;
            }

            @if (message.Type == MessageTypes.Call)
            {
                <div class="mb-3 flex justify-center">
                    <div class="rounded-full bg-current-100 px-5 py-1.5 dark:bg-current-500/20">
                        <p class="text-xs text-current-700 dark:text-current-300">@message.Contenido</p>
                    </div>
                </div>
            }
            else
            {
                <LIN.Allo.Shared.Components.Elements.Message
                    MessageModel="@message"
                    ShowTittle="(lastMessage?.Time != message.Time) || lastMessage == null || lastMessage?.Remitente?.Id != message.Remitente?.Id" />
            }

            lastMessage = message;
        }

        @(oldTime = null)
    </div>

</div>


@{
    string[] emojis = "🙌;👍;😁;👌;😍;❤️;😂;😊".Split(';');
}


@* Barra de entrada *@
<div class="border-t border-gray-100 bg-white px-4 pb-3 pt-2 dark:border-zinc-800 dark:bg-zinc-900">

    @* Reacciones rápidas *@
    <div class="mb-1.5 flex justify-end gap-0.5">
        @foreach (var emoji in emojis)
        {
            <button @onclick="() => SendMessage(emoji)"
                    class="flex h-7 w-7 items-center justify-center rounded-full text-base transition-colors hover:bg-gray-100 dark:hover:bg-zinc-800">
                @emoji
            </button>
        }
    </div>

    @* Input principal *@
    <div class="flex items-center gap-2 rounded-2xl border border-gray-100 bg-gray-50 px-4 py-2.5 dark:border-zinc-700/60 dark:bg-zinc-800">

        @* Botón GIF / Emoji *@
        <button @onclick="OpenGift" id="gift-panel"
                class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full transition-colors hover:bg-gray-200 dark:hover:bg-zinc-700">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
                 class="h-5 w-5 fill-gray-400 transition-colors hover:fill-current-500 dark:fill-zinc-400 dark:hover:fill-current-400">
                <path d="M9.153 11.603c.795 0 1.439-.879 1.439-1.962s-.644-1.962-1.439-1.962-1.439.879-1.439 1.962.644 1.962 1.439 1.962zm-3.204 1.362c-.026-.307-.131 5.218 6.063 5.551 6.066-.25 6.066-5.551 6.066-5.551-6.078 1.416-12.129 0-12.129 0zm11.363 1.108s-.669 1.959-5.051 1.959c-3.505 0-5.388-1.164-5.607-1.959 0 0 5.912 1.055 10.658 0zM11.804 1.011C5.609 1.011.978 6.033.978 12.228s4.826 10.761 11.021 10.761S23.02 18.423 23.02 12.228c.001-6.195-5.021-11.217-11.216-11.217zM12 21.354c-5.273 0-9.381-3.886-9.381-9.159s3.942-9.548 9.215-9.548 9.548 4.275 9.548 9.548c-.001 5.272-4.109 9.159-9.382 9.159zm3.108-9.751c.795 0 1.439-.879 1.439-1.962s-.644-1.962-1.439-1.962-1.439.879-1.439 1.962.644 1.962 1.439 1.962z" />
            </svg>
        </button>

        @* Campo de texto *@
        <input @oninput="GetValue" @bind="Message" @onkeydown="SendMessageKey"
               class="flex-1 bg-transparent text-sm text-gray-800 placeholder-gray-400 outline-none dark:text-gray-100 dark:placeholder-zinc-500"
               placeholder="Escribe un mensaje..."
               type="text"
               autocomplete="off" />

        @* Botón enviar *@
        <button @onclick="SendMessage"
                class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-current-500 text-white transition-colors hover:bg-current-600 active:bg-current-700">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" class="h-4 w-4 fill-white">
                <path d="M15.964.686a.5.5 0 0 0-.65-.65L.767 5.855H.766l-.452.18a.5.5 0 0 0-.082.887l.41.26.001.002 4.995 3.178 3.178 4.995.002.002.26.41a.5.5 0 0 0 .886-.083zm-1.833 1.89L6.637 10.07l-.215-.338a.5.5 0 0 0-.154-.154l-.338-.215 7.494-7.494 1.178-.471z" />
            </svg>
        </button>

    </div>
</div>

<Gifts @ref="GiftPanel" OnGifSelected="GiftSelect"></Gifts>
